---
import { typograf } from "../lib/typograf";

const slogan = typograf("прямые агенты в Корее — без посредников и рисков");
---

<header class="w-full py-6 px-4 md:px-8">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center md:justify-between gap-4">
    <!-- Название -->
    <div class="flex-shrink-0 flex items-center gap-2">
      <span class="font-heading text-lg md:text-xl font-bold tracking-tight text-[var(--korea-red)]">
        KOREA MOTORS
      </span>
      <span class="text-xs md:text-sm font-semibold text-white bg-[var(--korea-red)] px-2.5 py-0.5 md:px-3 md:py-1 rounded-full whitespace-nowrap">
        в&nbsp;Томске
      </span>
    </div>

    <!-- Слоган -->
    <div class="text-center md:text-right">
      <p class="text-sm md:text-base text-muted-foreground font-medium" set:html={slogan} />
    </div>
  </div>
</header>
